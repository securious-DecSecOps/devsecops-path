# AWS EC2/K3s profile for the Shared-DB based VulnBank MSA PoC.
# Copy this file to a private .env file in Jenkins or on the AWS VM.
# Do not commit real credentials, kubeconfig files, or registry passwords.

# Workload identity.
WORKLOAD_NAME=vulnbank-msa
APP_NAME=vulnbank-msa
MSA_WORKLOAD_DIR=examples/vulnbank-msa
SERVICES=user-service,transaction-service,status-service,file-service,settings-service,frontend

# Kubernetes target.
# Change this when the AWS/K3s namespace differs from the local profile.
NAMESPACE=security-lab
KUBECONFIG=/var/jenkins_home/kubeconfig

# Registry target.
# Local kind uses localhost:9092, but AWS must not use localhost.
# Use either:
# - ECR: <aws-account-id>.dkr.ecr.<region>.amazonaws.com
# - Harbor: harbor.example.com or harbor.example.com:443
REGISTRY_URL=<ecr-or-harbor-dns>
REGISTRY_PROJECT=secure-delivery

# Image tag policy.
# Jenkinsfile.msa uses BUILD_NUMBER when IMAGE_TAG is empty.
# For reproducible AWS promotion, set this to a Jenkins build number, Git SHA, or release tag.
IMAGE_TAG=<jenkins-build-number-or-git-sha>

# Deployment mode.
# helm is useful for first AWS smoke tests.
# argocd is the recommended GitOps mode after ArgoCD is installed in the K3s cluster.
DEPLOY_MODE=argocd
HELM_RELEASE=vulnbank-msa
HELM_CHART_DIR=helm/vulnbank-msa
GITOPS_APP_DIR=gitops/apps/vulnbank-msa/dev
ARGOCD_APP_MANIFEST=argocd/applications/vulnbank-msa-dev.yaml
ARGOCD_APP_NAME=vulnbank-msa-dev

# Security gate.
# AWS profile should normally enforce the gate before registry push and deployment.
ENFORCE_GATE=true
GATE_MAX_CRITICAL=0
GATE_MAX_HIGH=3

# Evidence output.
# Jenkins normally sets REPORT_DIR=reports/dev/<BUILD_NUMBER>.
# Keep this value only for manual AWS smoke tests.
REPORT_DIR=reports/aws-k3s/manual

# Frontend endpoint for post-deploy evidence collection.
# Leave empty when collect-msa-evidence.sh should try kubectl port-forward automatically.
# Set this when an Ingress, LoadBalancer, or SSH tunnel exposes the frontend.
FRONTEND_URL=
FRONTEND_SERVICE=vulnbank-msa-frontend
FRONTEND_LOCAL_PORT=18080

# K3s shared database service.
# Helm values use this service name for all PHP services.
DB_HOST=vulnbank-db
DB_NAME=vulnbank
DB_USER=root
DB_PASSWORD=

# Registry credentials.
# Prefer Jenkins Credentials, IAM role based ECR login, or Harbor robot account.
# Do not store real secrets in this file.
# REGISTRY_USERNAME=<jenkins-credential-or-robot-account>
# REGISTRY_PASSWORD=<jenkins-credential-secret>

# ECR login example for Jenkins shell stage.
# aws ecr get-login-password --region <region> | docker login --username AWS --password-stdin <aws-account-id>.dkr.ecr.<region>.amazonaws.com

# Harbor login example for Jenkins shell stage.
# docker login "${REGISTRY_URL}" --username "${REGISTRY_USERNAME}" --password-stdin
