WORKLOAD_NAME=simple-web
WORKLOAD_DIR=examples/simple-web
APP_NAME=simple-web
DOCKERFILE_PATH=examples/simple-web/Dockerfile
BUILD_CONTEXT=examples/simple-web
NAMESPACE=secure-path-dev
REGISTRY_URL=localhost:9092
REGISTRY_PROJECT=secure-delivery
IMAGE_TAG=dev
IMAGE=localhost:9092/secure-delivery/simple-web:dev
KUBECONFIG=/var/jenkins_home/kubeconfig
REPORT_DIR=reports/dev/local
DEPLOY_MODE=kubectl
ENFORCE_GATE=false
HELM_RELEASE=simple-web
HELM_CHART_DIR=helm/simple-web
GITOPS_APP_DIR=gitops/apps/simple-web/dev

# Local smoke-test fallback only. Do not use these as production secrets.
# REGISTRY_USERNAME=admin
# REGISTRY_PASSWORD=Harbor12345

